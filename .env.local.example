# Supabase credentials
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: disable email confirmation in Supabase Dashboard →
# Authentication → Settings → "Enable email confirmations" OFF
# for a smoother signup flow during development.

# Investor Intelligence ingestion (server-only; bypasses RLS).
# Supabase → Settings → API → "service_role" key. NEVER commit or expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
